@startuml name

title Προσθήκη Τραγουδιού σε Λίστα Αναπαραγωγής

'Υποθετουμε οτι εχουμε είδη βρει την ΛΑ

actor User 
participant TopBarView
participant TopBarController
participant Playlist 
participant Song
participant SongControllerAPI
participant SongService
participant SongRepository
participant PlaylistControllerAPI
participant PlaylistService
participant PlaylistRepository


activate TopBarController
activate TopBarView
User -> TopBarView : selectSong()
TopBarView -> TopBarView : displaySongOptions()
alt User selects "Add to Playlist"
User -> TopBarView : selectAddToPlaylist()
TopBarView -> TopBarController : addToPlaylist()
TopBarController -> Playlist : fetchPlaylistsById(userId)
activate Playlist
Playlist -> PlaylistControllerAPI : findByUserId(userId)
activate PlaylistControllerAPI
PlaylistControllerAPI -> PlaylistService : createQuery(userId)
activate PlaylistService
PlaylistService -> PlaylistRepository : runQuery()
activate PlaylistRepository
PlaylistRepository --> PlaylistService : playlist rows
deactivate PlaylistRepository
PlaylistService --> PlaylistControllerAPI : List<Playlists>
deactivate PlaylistService
PlaylistControllerAPI --> Playlist : List<Playlists>
deactivate PlaylistControllerAPI
Playlist --> TopBarController : List<Playlists>
deactivate Playlist
TopBarController -> TopBarView : showAvailablePlaylists()
User -> TopBarView : selectPlaylist()
TopBarView -> TopBarController : addSongToPlaylist()
TopBarController -> Playlist : getPlaylistSongs()
activate Playlist
Playlist -> Song : getSongsByPlaylistId(playlistId)
activate Song
Song -> SongControllerAPI : fetchSongByPlId(plId)
activate SongControllerAPI
SongControllerAPI -> SongService : findByPlaylistId(plId)
activate SongService
SongService -> SongRepository : runQuery()
activate SongRepository
SongRepository --> SongService : song rows
deactivate SongRepository
SongService --> SongControllerAPI : List<Songs>
deactivate SongService
SongControllerAPI --> Song : List<Songs>
deactivate SongControllerAPI
Song --> Playlist : List<Songs>
deactivate Song
Playlist -> TopBarController : List<Songs>
Playlist -> Playlist : checkIfSongExists(songId)
alt Song doesn't exist in Playlist
Playlist -> PlaylistControllerAPI : addSongToPlaylist(songId, playlistId)
activate PlaylistControllerAPI
PlaylistControllerAPI -> PlaylistService : addSongToPlaylist(songId, playlistId)
activate PlaylistService
PlaylistService -> PlaylistRepository : runQuery()
activate PlaylistRepository
PlaylistRepository --> PlaylistService : success
deactivate PlaylistRepository
PlaylistService --> PlaylistControllerAPI : success
deactivate PlaylistService
PlaylistControllerAPI --> Playlist : success
deactivate PlaylistControllerAPI
Playlist -> TopBarController : song added successfully
else Song already exists in Playlist
Playlist -> TopBarController : song already in playlist
end
else User selects add to Favourites
User -> TopBarView : selectAddToFavourites()
TopBarView -> TopBarController : addToFavourites()
TopBarController -> Song : addToFavourites(songId, userId)
activate Song
Song -> SongControllerAPI : addToFavourites(songId, userId)
activate SongControllerAPI
SongControllerAPI -> SongService : addToFavourites(songId, userId)
activate SongService
SongService -> SongRepository : runQuery()
activate SongRepository
SongRepository --> SongService : success
deactivate SongRepository
SongService --> SongControllerAPI : success
deactivate SongService
SongControllerAPI --> Song : success
deactivate Song
Song -> TopBarController : song added to favourites successfully
end 


@enduml 