@startuml name

title Login

actor User
participant LoginView
participant LoginController
participant UserService
participant UserAPI
participant UserBackendController
participant UserBackendService
participant UserRepository
database Database


User -> LoginView : Enter username and password
LoginView -> LoginController : login(username, password)
activate LoginController
LoginController -> UserService : getUserByUsername(username)
activate UserService
UserService -> UserAPI : getUserByUsername(username)
activate UserAPI
UserAPI -> UserBackendController : getUserByUsername(username)
activate UserBackendController
UserBackendController -> UserBackendService : getUserByUsername(username)
activate UserBackendService
UserBackendService -> UserRepository : getUserByUsername(username)
activate UserRepository
UserRepository -> Database : Execute SQL to find user by username
Database --> UserRepository : Return user data or null
UserRepository --> UserBackendService : Return user data or null
deactivate UserRepository
UserBackendService --> UserBackendController : Return user data or null
deactivate UserBackendService
UserBackendController --> UserAPI : Return user data or null
deactivate UserBackendController
UserAPI --> UserService : Return user data or null
deactivate UserAPI
UserService --> LoginController : Return user data or null
deactivate UserService
LoginController -> LoginController : validateCredentials()
alt "User not found"
    LoginController --> LoginView : Show error message "User not found"
else "User found"
    alt "Password matches"
        LoginController --> LoginView : Show success message and proceed to next screen
    else "Password does not match"
        LoginController --> LoginView : Show error message "Incorrect password"
    end
end
deactivate LoginController


@enduml